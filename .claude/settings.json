{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "command": "pnpm prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
      },
      {
        "matcher": "Edit",
        "command": "pnpm prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
      },
      {
        "matcher": "Write",
        "command": "pnpm eslint --fix \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
      },
      {
        "matcher": "Edit",
        "command": "pnpm eslint --fix \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
      }
    ],
    "Stop": [
      {
        "command": "pnpm test 2>/dev/null || echo 'No tests configured'"
      },
      {
        "command": "echo '\\n💡 Reminder: Run /init to update CLAUDE.md if needed\\n'"
      }
    ]
  }
}
