{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "command": "node .claude/hooks/block-env-read.js"
      },
      {
        "matcher": "Bash",
        "command": "node .claude/hooks/block-dangerous-git.js"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "command": "pnpm prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
      },
      {
        "matcher": "Edit",
        "command": "pnpm prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true"
      },
      {
        "matcher": "Write",
        "command": "node .claude/hooks/lint-with-feedback.js"
      },
      {
        "matcher": "Edit",
        "command": "node .claude/hooks/lint-with-feedback.js"
      },
      {
        "matcher": "Write",
        "command": "node .claude/hooks/typecheck.js"
      },
      {
        "matcher": "Edit",
        "command": "node .claude/hooks/typecheck.js"
      },
      {
        "matcher": "Write",
        "command": "node .claude/hooks/detect-secrets.js"
      },
      {
        "matcher": "Edit",
        "command": "node .claude/hooks/detect-secrets.js"
      },
      {
        "matcher": "Write",
        "command": "node .claude/hooks/detect-duplicates.js"
      },
      {
        "matcher": "Edit",
        "command": "node .claude/hooks/detect-duplicates.js"
      },
      {
        "matcher": "Write",
        "command": "node .claude/hooks/detect-missing-tests.js"
      },
      {
        "matcher": "Edit",
        "command": "node .claude/hooks/detect-missing-tests.js"
      },
      {
        "matcher": "Write",
        "command": "node .claude/hooks/check-complexity.js"
      },
      {
        "matcher": "Edit",
        "command": "node .claude/hooks/check-complexity.js"
      },
      {
        "matcher": "Write",
        "command": "node .claude/hooks/detect-dead-code.js"
      },
      {
        "matcher": "Edit",
        "command": "node .claude/hooks/detect-dead-code.js"
      },
      {
        "matcher": "Write",
        "command": "node .claude/hooks/track-tech-debt.js"
      },
      {
        "matcher": "Edit",
        "command": "node .claude/hooks/track-tech-debt.js"
      }
    ],
    "UserPromptSubmit": [
      {
        "command": "node .claude/hooks/user-prompt-context.js"
      }
    ],
    "PreCompact": [
      {
        "command": "node .claude/hooks/pre-compact-snapshot.js"
      }
    ],
    "SessionStart": [
      {
        "command": "node .claude/hooks/session-context.js"
      }
    ],
    "Stop": [
      {
        "command": "node .claude/hooks/save-session-notes.js"
      },
      {
        "command": "node .claude/hooks/pre-pr-checklist.js"
      },
      {
        "command": "pnpm test 2>/dev/null || echo 'No tests configured'"
      },
      {
        "command": "echo '\\n💡 Reminder: Run /log-auto before closing the session\\n'"
      }
    ]
  }
}
