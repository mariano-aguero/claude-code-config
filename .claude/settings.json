{
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_FORMAT": "1",
    "CLAUDE_LINT": "1",
    "CLAUDE_ANALYSIS": "1",
    "CLAUDE_RUN_TESTS": "0"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-env-read.js"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-dangerous-git.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/block-env-read.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ \"${CLAUDE_FORMAT:-1}\" = \"0\" ] || pnpm prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true'"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/lint-with-feedback.js"
          },
          { "type": "command", "command": "node .claude/hooks/typecheck.js" },
          { "type": "command", "command": "node .claude/hooks/analysis.js" },
          {
            "type": "command",
            "command": "node .claude/hooks/track-tech-debt.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/detect-dead-code.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/detect-duplicates.js"
          },
          { "type": "command", "command": "node .claude/hooks/auto-stage.js" }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ \"${CLAUDE_FORMAT:-1}\" = \"0\" ] || pnpm prettier --write \"$CLAUDE_FILE_PATH\" 2>/dev/null || true'"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/lint-with-feedback.js"
          },
          { "type": "command", "command": "node .claude/hooks/typecheck.js" },
          { "type": "command", "command": "node .claude/hooks/analysis.js" },
          {
            "type": "command",
            "command": "node .claude/hooks/track-tech-debt.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/detect-dead-code.js"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/detect-duplicates.js"
          },
          { "type": "command", "command": "node .claude/hooks/auto-stage.js" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/user-prompt-context.js"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-compact-snapshot.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/session-context.js"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/notify.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/save-session-notes.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/detect-duplicates.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/pre-pr-checklist.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c '[ \"${CLAUDE_RUN_TESTS:-0}\" = \"1\" ] && pnpm test 2>/dev/null || true'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\n💡 Reminder: Run /log-auto before closing the session\\n'"
          }
        ]
      }
    ]
  }
}
