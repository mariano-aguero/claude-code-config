# ============================================================================
# Claude AI Templates - .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# IDE & Editors
# ----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
*.code-workspace

# ----------------------------------------------------------------------------
# OS Generated Files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----------------------------------------------------------------------------
# Claude Code Local Settings (user-specific)
# ----------------------------------------------------------------------------
.claude/settings.local.json

# ----------------------------------------------------------------------------
# Claude Code Hook-generated files (session state, not code artifacts)
# ----------------------------------------------------------------------------
.claude/session-notes.md
.claude/tech-debt.md
.claude/pr-checklist.md
.claude/pre-compact-snapshot.md

# ----------------------------------------------------------------------------
# Claude Code Planning docs (local brainstorming, not code artifacts)
# ----------------------------------------------------------------------------
docs/plans/

# ----------------------------------------------------------------------------
# Node.js (if using any tooling)
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ----------------------------------------------------------------------------
# Environment Variables
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example

# ----------------------------------------------------------------------------
# Temporary Files
# ----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
.cache/
tmp/
temp/

# ----------------------------------------------------------------------------
# Draft / Work in Progress Files
# ----------------------------------------------------------------------------
*.draft.md
*.wip.md
*.backup.md
_drafts/
_wip/

# ----------------------------------------------------------------------------
# Local Testing / Scratch Files
# ----------------------------------------------------------------------------
scratch/
local/
test-output/
.local/

# ----------------------------------------------------------------------------
# Build Output (if any)
# ----------------------------------------------------------------------------
dist/
build/
out/

# ----------------------------------------------------------------------------
# Archive / Deprecated
# ----------------------------------------------------------------------------
_archive/
_deprecated/
_old/
